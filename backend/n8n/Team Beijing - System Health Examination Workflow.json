            {
              "id": "e0fa63e0-5ba2-4c3d-b783-dd4d6f6d54c4",
              "leftValue": "={{ $json.is_active_window }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}

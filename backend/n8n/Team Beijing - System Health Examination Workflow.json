    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst sunrise = new Date($input.first().json.results.sunrise);\nconst sunset = new Date($input.first().json.results.sunset);\n\nconst activeStart = new Date(sunrise.getTime() + 60 * 60 * 1000);\nconst activeEnd = new Date(sunset.getTime() - 60 * 60 * 1000);\n\nreturn [{\n  json: {\n    is_active_window: now >= activeStart && now <= activeEnd,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
